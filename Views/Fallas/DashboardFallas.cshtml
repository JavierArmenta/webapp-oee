@{
    ViewData["Title"] = "Dashboard de Fallas";
}

<style>
    /* Hero */
    .lnx-hero {
        background: linear-gradient(135deg, #7c2d12 0%, #c2410c 100%);
        border-radius: 0.375rem;
        padding: 2.5rem 2rem;
        color: #fff;
        position: relative;
        overflow: hidden;
        margin-bottom: 1.75rem;
    }

    .lnx-hero::after {
        content: '';
        position: absolute;
        right: -40px;
        top: -40px;
        width: 220px;
        height: 220px;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 50%;
    }

    .lnx-hero::before {
        content: '';
        position: absolute;
        right: 60px;
        bottom: -60px;
        width: 160px;
        height: 160px;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 50%;
    }

    .lnx-hero h1 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.4rem;
    }

    .lnx-hero p {
        opacity: 0.8;
        margin-bottom: 0;
        font-size: 0.9375rem;
    }

    .lnx-hero .hero-icon {
        font-size: 5rem;
        opacity: 0.12;
        position: absolute;
        right: 2rem;
        top: 50%;
        transform: translateY(-50%);
        line-height: 1;
    }
</style>

<div class="container-fluid">

    <!-- Hero Section -->
    <div class="lnx-hero">
        <div style="position: relative; z-index: 1;">
            <h1>
                <i class="ph ph-clock me-2"></i>Paros Timeline
            </h1>
            <p>Gestiona y monitorea los paros en tiempo real</p>
        </div>
        <i class="ph ph-warning hero-icon"></i>
    </div>

    <!-- Filtros -->
    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-lg-2">
                    <label class="small fw-semibold">Máquina</label>
                    <select id="maquinaId" class="form-select form-select-sm">
                        <option value="">Todas las máquinas</option>
                        @foreach (var maquina in ViewBag.Maquinas as IEnumerable<WebApp.Models.Maquina>)
                        {
                            <option value="@maquina.Id">@maquina.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2">
                    <label class="small fw-semibold">Rango de Tiempo</label>
                    <select id="rangoTiempoFallas" class="form-select form-select-sm">
                        <option value="turno-actual">Turno Actual</option>
                        <option value="24h" selected>24 Horas</option>
                        <option value="semana">Semana</option>
                        <option value="mes">Mes</option>
                    </select>
                </div>
                <div class="col-lg-2">
                    <button type="button" class="btn btn-success w-100" id="btnBuscar" onclick="cargarDatos()">
                        <i class="ph ph-arrows-clockwise me-1"></i>Actualizar ahora
                    </button>
                </div>
                <div class="col-lg-6 text-end">
                    <small class="text-muted" id="lastUpdateTime">—</small>
                </div>
            </div>

            <!-- Barra de Progreso de Recarga -->
            <div class="dl-refresh-bar" style="margin-top: 1.25rem; margin-bottom: 0;">
                <div class="dl-refresh-progress" id="progressBar" style="width: 0%;"></div>
            </div>
        </div>
    </div>

    <style>
        .dl-refresh-bar {
            height: 3px;
            background: #e2e8f0;
            border-radius: 99px;
            overflow: hidden;
        }
        .dl-refresh-progress {
            height: 100%;
            background: #16a34a;
            border-radius: 99px;
            transition: width 1s linear;
        }
    </style>

    <!-- KPI Cards -->
    <div class="row g-3 mb-3">
        <div class="col-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small mb-1">Total Fallas</div>
                            <div class="fs-2 fw-bold lh-1" id="totalFallas">—</div>
                            <div class="text-muted small mt-2">en el período</div>
                        </div>
                        <div class="rounded-2 p-2" style="background:#f1f5f9">
                            <i class="ph ph-clipboard-text" style="font-size:1.6rem;color:#64748b"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card h-100 border-start border-warning border-3">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small mb-1">Pendientes</div>
                            <div class="fs-2 fw-bold lh-1 text-warning" id="fallasAbiertas">—</div>
                            <div class="text-muted small mt-2">sin atender</div>
                        </div>
                        <div class="rounded-2 p-2" style="background:#fff7ed">
                            <i class="ph ph-clock" style="font-size:1.6rem;color:#f59e0b"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card h-100 border-start border-info border-3">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small mb-1">En Atención</div>
                            <div class="fs-2 fw-bold lh-1 text-info" id="fallasEnAtencion">—</div>
                            <div class="text-muted small mt-2">en proceso</div>
                        </div>
                        <div class="rounded-2 p-2" style="background:#ecfeff">
                            <i class="ph ph-wrench" style="font-size:1.6rem;color:#0891b2"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card h-100 border-start border-success border-3">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small mb-1">Resueltas</div>
                            <div class="fs-2 fw-bold lh-1 text-success" id="fallasResueltas">—</div>
                            <div class="text-muted small mt-2" id="tasaResolucionLabel">—</div>
                        </div>
                        <div class="rounded-2 p-2" style="background:#f0fdf4">
                            <i class="ph ph-check-circle" style="font-size:1.6rem;color:#16a34a"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MTTR + Tasa de resolución -->
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="card h-100 border-start border-primary border-3">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between">
                        <div>
                            <div class="text-muted small mb-1">MTTR</div>
                            <div class="lh-1">
                                <span class="fs-2 fw-bold text-primary" id="mttr">—</span>
                                <span class="text-muted ms-1">min</span>
                            </div>
                            <div class="text-muted small mt-2">Mean Time To Repair</div>
                        </div>
                        <div class="rounded-2 p-2" style="background:#eff6ff">
                            <i class="ph ph-timer" style="font-size:1.6rem;color:#2563eb"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card h-100">
                <div class="card-body d-flex flex-column justify-content-center">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small text-muted fw-semibold">Tasa de Resolución</span>
                        <span class="small fw-bold" id="tasaResolucionPct">—</span>
                    </div>
                    <div class="progress" style="height:10px;border-radius:99px">
                        <div class="progress-bar bg-success" id="progressResolucion"
                             role="progressbar" style="width:0%;border-radius:99px"
                             aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <span class="text-muted" style="font-size:.75rem">0%</span>
                        <span class="text-muted" style="font-size:.75rem">100%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>



    <!-- Loading -->
    <div id="loadingCharts" class="text-center py-5 d-none">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="text-muted mt-3 mb-0">Cargando datos...</p>
    </div>

    <!-- Error state -->
    <div id="errorState" class="d-none">
        <div class="alert alert-danger d-flex gap-2 align-items-start">
            <i class="ph ph-warning-circle mt-1"></i>
            <div>
                <strong>Error al cargar los datos</strong>
                <div class="small mt-1" id="errorMsg"></div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div id="chartsContainer">
        <!-- Row 1: Top 10 + Severidad -->
        <div class="row g-3 mb-3">
            <div class="col-xl-7">
                <div class="card h-100">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="ph ph-chart-bar me-2"></i>Top 10 Fallas Más Frecuentes</h5>
                    </div>
                    <div class="card-body">
                        <div style="position:relative;height:280px">
                            <canvas id="chartTop10Fallas"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-5">
                <div class="card h-100">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="ph ph-chart-pie-slice me-2"></i>Por Severidad</h5>
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <div style="position:relative;height:280px;width:100%">
                            <canvas id="chartSeveridad"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Row 2: Categoría + Máquinas -->
        <div class="row g-3 mb-3">
            <div class="col-xl-5">
                <div class="card h-100">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="ph ph-tag me-2"></i>Por Categoría</h5>
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center">
                        <div style="position:relative;height:280px;width:100%">
                            <canvas id="chartCategoria"></canvas>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-7">
                <div class="card h-100">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="ph ph-factory me-2"></i>Top 10 Máquinas con Más Fallas</h5>
                    </div>
                    <div class="card-body">
                        <div style="position:relative;height:280px">
                            <canvas id="chartMaquinas"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Row 3: Tendencia diaria -->
        <div class="row g-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="ph ph-trend-up me-2"></i>Tendencia Diaria de Fallas</h5>
                    </div>
                    <div class="card-body">
                        <div style="position:relative;height:200px">
                            <canvas id="chartTendencia"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        let chartTop10, chartSeveridad, chartCategoria, chartMaquinas, chartTendencia;

        // Global Chart.js defaults
        Chart.defaults.font.family = 'Inter, system-ui, sans-serif';
        Chart.defaults.font.size = 12;
        Chart.defaults.color = '#64748b';
        Chart.defaults.plugins.tooltip.padding = 10;
        Chart.defaults.plugins.tooltip.cornerRadius = 6;
        Chart.defaults.plugins.tooltip.titleFont = { size: 12, weight: '600' };

        const SEVERIDAD_COLORS = {
            'Crítica': '#ef4444',
            'Alta':    '#f97316',
            'Media':   '#eab308',
            'Baja':    '#22c55e',
            'Sin clasificar': '#94a3b8'
        };

        const CATEGORIA_PALETTE = [
            '#6366f1', '#8b5cf6', '#ec4899', '#f43f5e',
            '#0ea5e9', '#14b8a6', '#f59e0b', '#10b981'
        ];

        function updateTimestamp() {
            const now = new Date();
            const hh = String(now.getHours()).padStart(2, '0');
            const mm = String(now.getMinutes()).padStart(2, '0');
            const ss = String(now.getSeconds()).padStart(2, '0');
            document.getElementById('lastUpdateTime').textContent = `Última actualización: ${hh}:${mm}:${ss}`;
        }

        document.addEventListener('DOMContentLoaded', function () {
            updateTimestamp();
            cargarDatos();
            
            // Event listener para selector de rango
            document.getElementById('rangoTiempoFallas').addEventListener('change', function() {
                resetProgressBar();
                cargarDatos();
            });

            // Event listener para selector de máquina
            document.getElementById('maquinaId').addEventListener('change', function() {
                resetProgressBar();
                cargarDatos();
            });

            // Event listener para botón actualizar
            document.getElementById('btnBuscar').addEventListener('click', function() {
                resetProgressBar();
            });
        });

        // Barra de progreso de recarga automática
        (function() {
            let intervalId = null;
            let progress = 0;
            const progressBar = document.getElementById('progressBar');
            const INTERVAL = 30000; // 30 segundos

            function resetProgressBar() {
                progress = 0;
                progressBar.style.width = '0%';
                clearInterval(intervalId);
                
                intervalId = setInterval(function() {
                    progress += 1;
                    progressBar.style.width = progress + '%';
                    if (progress >= 100) {
                        clearInterval(intervalId);
                        cargarDatos();
                        resetProgressBar();
                    }
                }, INTERVAL / 100);
            }

            window.resetProgressBar = resetProgressBar;
            resetProgressBar();
        })();

        function setLoading(loading) {
            const spinner  = document.getElementById('loadingCharts');
            const charts   = document.getElementById('chartsContainer');
            const btn      = document.getElementById('btnBuscar');
            if (loading) {
                spinner.classList.remove('d-none');
                charts.style.opacity = '0.35';
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Cargando…';
            } else {
                spinner.classList.add('d-none');
                charts.style.opacity = '1';
                btn.disabled = false;
                btn.innerHTML = '<i class="ph ph-arrows-clockwise me-1"></i>Actualizar ahora';
            }
        }

        function cargarDatos() {
            const rangoTiempo = document.getElementById('rangoTiempoFallas').value;
            const maquinaId   = document.getElementById('maquinaId').value;

            document.getElementById('errorState').classList.add('d-none');
            setLoading(true);

            const url = `/Fallas/GetDatosFallas?rangoTiempo=${rangoTiempo}&maquinaId=${maquinaId}`;

            fetch(url)
                .then(r => {
                    if (!r.ok) throw new Error(`HTTP ${r.status}`);
                    return r.json();
                })
                .then(data => {
                    setLoading(false);
                    if (data.error) {
                        mostrarError(data.mensaje + (data.detalle ? ` — ${data.detalle}` : ''));
                        return;
                    }
                    actualizarResumen(data);
                    actualizarGraficas(data);
                })
                .catch(err => {
                    setLoading(false);
                    mostrarError(err.message);
                });
        }

        function mostrarError(msg) {
            document.getElementById('errorMsg').textContent = msg;
            document.getElementById('errorState').classList.remove('d-none');
        }

        function actualizarResumen(data) {
            document.getElementById('totalFallas').textContent     = data.totalFallas ?? 0;
            document.getElementById('fallasAbiertas').textContent  = data.fallasAbiertas ?? 0;
            document.getElementById('fallasEnAtencion').textContent= data.fallasEnAtencion ?? 0;
            document.getElementById('fallasResueltas').textContent = data.fallasResueltas ?? 0;
            document.getElementById('mttr').textContent            = data.mttr ?? '—';

            const total = data.totalFallas || 0;
            const resueltas = data.fallasResueltas || 0;
            const pct = total > 0 ? Math.round((resueltas / total) * 100) : 0;
            document.getElementById('tasaResolucionLabel').textContent = total > 0 ? `${pct}% del total` : 'sin datos';
            document.getElementById('tasaResolucionPct').textContent   = total > 0 ? `${pct}%` : '—';
            const bar = document.getElementById('progressResolucion');
            bar.style.width      = pct + '%';
            bar.setAttribute('aria-valuenow', pct);

            updateTimestamp();
        }

        function actualizarGraficas(data) {
            if (!data?.top10Fallas) return;

            const gridColor  = 'rgba(0,0,0,.05)';
            const tooltipBg  = '#1e293b';

            // ── Top 10 Fallas (bar, vertical) ──────────────────────────
            if (chartTop10) chartTop10.destroy();
            const top10Labels = data.top10Fallas.length ? data.top10Fallas.map(f => f.nombre) : ['Sin datos'];
            const top10Data   = data.top10Fallas.length ? data.top10Fallas.map(f => f.cantidad) : [0];
            const top10Colors = data.top10Fallas.length ? data.top10Fallas.map(f => f.color || '#6366f1') : ['#e2e8f0'];
            chartTop10 = new Chart(document.getElementById('chartTop10Fallas'), {
                type: 'bar',
                data: {
                    labels: top10Labels,
                    datasets: [{
                        label: 'Ocurrencias',
                        data: top10Data,
                        backgroundColor: top10Colors.map(c => c + 'cc'),
                        borderColor: top10Colors,
                        borderWidth: 1,
                        borderRadius: 4,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: tooltipBg,
                            callbacks: {
                                label: ctx => `  ${ctx.parsed.y} ocurrencia${ctx.parsed.y !== 1 ? 's' : ''}`
                            }
                        }
                    },
                    scales: {
                        x: { grid: { color: gridColor }, ticks: { maxRotation: 35, minRotation: 20 } },
                        y: { grid: { color: gridColor }, beginAtZero: true, ticks: { stepSize: 1 } }
                    }
                }
            });

            // ── Severidad (doughnut) ────────────────────────────────────
            if (chartSeveridad) chartSeveridad.destroy();
            chartSeveridad = new Chart(document.getElementById('chartSeveridad'), {
                type: 'doughnut',
                data: {
                    labels: data.porSeveridad.map(s => s.severidad),
                    datasets: [{
                        data: data.porSeveridad.map(s => s.cantidad),
                        backgroundColor: data.porSeveridad.map(s => SEVERIDAD_COLORS[s.severidad] || '#94a3b8'),
                        borderWidth: 2,
                        borderColor: '#fff',
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '62%',
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 14, usePointStyle: true } },
                        tooltip: {
                            backgroundColor: tooltipBg,
                            callbacks: {
                                label: ctx => {
                                    const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                                    const pct = total ? Math.round((ctx.parsed / total) * 100) : 0;
                                    return `  ${ctx.label}: ${ctx.parsed} (${pct}%)`;
                                }
                            }
                        }
                    }
                }
            });

            // ── Categoría (doughnut) ────────────────────────────────────
            if (chartCategoria) chartCategoria.destroy();
            chartCategoria = new Chart(document.getElementById('chartCategoria'), {
                type: 'doughnut',
                data: {
                    labels: data.porCategoria.map(c => c.categoria),
                    datasets: [{
                        data: data.porCategoria.map(c => c.cantidad),
                        backgroundColor: CATEGORIA_PALETTE,
                        borderWidth: 2,
                        borderColor: '#fff',
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '62%',
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 14, usePointStyle: true } },
                        tooltip: {
                            backgroundColor: tooltipBg,
                            callbacks: {
                                label: ctx => {
                                    const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                                    const pct = total ? Math.round((ctx.parsed / total) * 100) : 0;
                                    return `  ${ctx.label}: ${ctx.parsed} (${pct}%)`;
                                }
                            }
                        }
                    }
                }
            });

            // ── Máquinas (horizontal bar) ───────────────────────────────
            if (chartMaquinas) chartMaquinas.destroy();
            chartMaquinas = new Chart(document.getElementById('chartMaquinas'), {
                type: 'bar',
                data: {
                    labels: data.porMaquina.map(m => m.maquina),
                    datasets: [{
                        label: 'Fallas',
                        data: data.porMaquina.map(m => m.cantidad),
                        backgroundColor: 'rgba(99,102,241,.75)',
                        borderColor: '#6366f1',
                        borderWidth: 1,
                        borderRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    plugins: {
                        legend: { display: false },
                        tooltip: { backgroundColor: tooltipBg }
                    },
                    scales: {
                        x: { grid: { color: gridColor }, beginAtZero: true, ticks: { stepSize: 1 } },
                        y: { grid: { display: false } }
                    }
                }
            });

            // ── Tendencia diaria (area line) ────────────────────────────
            if (chartTendencia) chartTendencia.destroy();
            chartTendencia = new Chart(document.getElementById('chartTendencia'), {
                type: 'line',
                data: {
                    labels: data.tendenciaDiaria.map(t => t.fecha),
                    datasets: [{
                        label: 'Fallas / día',
                        data: data.tendenciaDiaria.map(t => t.cantidad),
                        borderColor: '#6366f1',
                        backgroundColor: (ctx) => {
                            const gradient = ctx.chart.ctx.createLinearGradient(0, 0, 0, ctx.chart.height);
                            gradient.addColorStop(0,   'rgba(99,102,241,.25)');
                            gradient.addColorStop(1,   'rgba(99,102,241,0)');
                            return gradient;
                        },
                        fill: true,
                        tension: 0.35,
                        pointRadius: 4,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#6366f1',
                        pointBorderWidth: 2,
                        pointHoverRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: tooltipBg,
                            callbacks: {
                                label: ctx => `  ${ctx.parsed.y} falla${ctx.parsed.y !== 1 ? 's' : ''}`
                            }
                        }
                    },
                    scales: {
                        x: { grid: { color: gridColor } },
                        y: { grid: { color: gridColor }, beginAtZero: true, ticks: { stepSize: 1 } }
                    }
                }
            });
        }
    </script>
}
