@model IEnumerable<WebApp.Models.Linealytics.Turno>

@{
    ViewData["Title"] = "Gestión de Turnos";
}

<div class="container-fluid">

    <div class="page-header">
        <h1 class="page-header-title">
            <i class="ph ph-clock-clockwise"></i>Turnos de Trabajo
        </h1>
        <a asp-action="CreateTurno" class="btn btn-primary btn-sm">
            <i class="ph ph-plus-circle me-1"></i>Nuevo Turno
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="ph ph-tray display-1 text-muted"></i>
                    <p class="text-muted mt-3">No hay turnos registrados.</p>
                    <a asp-action="CreateTurno" class="btn btn-primary">
                        <i class="ph ph-plus-circle me-1"></i>Crear primer turno
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle datatable-basic">
                        <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Hora Inicio</th>
                            <th>Hora Fin</th>
                            <th>Duración (min)</th>
                            <th class="text-center">Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(!item.Activo ? "table-secondary" : "")">
                                <td>
                                    <strong>@item.Nombre</strong>
                                </td>
                                <td>@item.HoraInicio.ToString(@"hh\:mm")</td>
                                <td>@item.HoraFin.ToString(@"hh\:mm")</td>
                                <td>
                                    <span class="badge bg-info">@item.DuracionMinutos min</span>
                                </td>
                                <td class="text-center">
                                    @if (item.Activo)
                                    {
                                        <span class="badge bg-success">
                                            <i class="ph ph-check me-1"></i>Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="ph ph-x me-1"></i>Inactivo
                                        </span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="EditTurno" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        <i class="ph ph-pencil-simple"></i> Editar
                                    </a>
                                    @if (item.Activo)
                                    {
                                        <form asp-action="DeactivateTurno" asp-route-id="@item.Id" method="post" class="d-inline deactivate-form">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-sm btn-warning deactivate-turno-btn">
                                                <i class="ph ph-toggle-left me-1"></i>Desactivar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="ActivateTurno" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success">
                                                <i class="ph ph-toggle-right me-1"></i>Activar
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/js/jquery/jquery.min.js"></script>
    <script src="~/assets/js/vendor/tables/datatables/datatables.min.js"></script>
    <script src="~/assets/js/vendor/notifications/sweet_alert.min.js"></script>
    <script src="~/assets/demo/pages/extra_sweetalert.js"></script>

    <script>
        const swalInit = swal.mixin({
            buttonsStyling: false,
            customClass: {
                confirmButton: 'btn btn-success',
                cancelButton: 'btn btn-danger'
            }
        });

        const _componentDatatableBasic = function() {
            if (!$().DataTable) {
                console.warn('Warning - datatables.min.js is not loaded.');
                return;
            }

            $.extend( $.fn.dataTable.defaults, {
                autoWidth: false,
                columnDefs: [{
                    orderable: false,
                    targets: [ 5 ],
                    width: '280px'
                }],
                dom: '<"datatable-header"fl>t<"datatable-footer"ip>',
                language: {
                    search: '<span class="me-3">Filter:</span> <div class="form-control-feedback form-control-feedback-end flex-fill">_INPUT_<div class="form-control-feedback-icon"><i class="ph-magnifying-glass opacity-50"></i></div></div>',
                    searchPlaceholder: 'Type to filter...',
                    lengthMenu: '<span class="me-3">Show:</span> _MENU_',
                    paginate: { 'first': 'First', 'last': 'Last', 'next': document.dir == "rtl" ? '&larr;' : '&rarr;', 'previous': document.dir == "rtl" ? '&rarr;' : '&larr;' }
                }
            });
            $('.datatable-basic').DataTable();
        };

        document.addEventListener('DOMContentLoaded', function() {
            _componentDatatableBasic();

            const deactivateButtons = document.querySelectorAll('.deactivate-turno-btn');
            deactivateButtons.forEach(function(button) {
                button.addEventListener('click', function() {
                    const form = this.closest('.deactivate-form');
                    swalInit.fire({
                        title: '¿Está seguro?',
                        text: "¿Desea desactivar este turno?",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Sí, desactivar',
                        cancelButtonText: 'No, cancelar',
                        buttonsStyling: false,
                        customClass: {
                            confirmButton: 'btn btn-success',
                            cancelButton: 'btn btn-danger'
                        }
                    }).then(function(result) {
                        if(result.value) {
                            form.submit();
                        }
                        else if(result.dismiss === swal.DismissReason.cancel) {
                            swalInit.fire('Cancelado', 'El turno no ha sido desactivado', 'info');
                        }
                    });
                });
            });

            @if (TempData["Success"] != null)
            {
                <text>
                swalInit.fire({
                    title: '¡Éxito!',
                    text: '@TempData["Success"]',
                    icon: 'success',
                    confirmButtonText: 'OK',
                    buttonsStyling: false,
                    customClass: {
                        confirmButton: 'btn btn-success'
                    }
                });
                </text>
            }

            @if (TempData["Error"] != null)
            {
                <text>
                swalInit.fire({
                    title: 'Error',
                    text: '@TempData["Error"]',
                    icon: 'error',
                    confirmButtonText: 'OK',
                    buttonsStyling: false,
                    customClass: {
                        confirmButton: 'btn btn-danger'
                    }
                });
                </text>
            }
        });
    </script>
}
