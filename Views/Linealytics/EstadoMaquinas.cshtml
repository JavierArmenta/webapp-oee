@{
    ViewData["Title"] = "Estado de Máquinas";
}

<style>
    /* ── Hero ── */
    .em-hero {
        background: linear-gradient(135deg, #0f2d52 0%, #1a4f8a 100%);
        border-radius: 0.375rem;
        padding: 1.75rem 2rem;
        color: #fff;
        position: relative;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }
    .em-hero h1 { font-size: 1.6rem; font-weight: 700; margin-bottom: 0.25rem; }
    .em-hero p  { opacity: 0.75; margin: 0; font-size: 0.9rem; }
    .em-hero .hero-icon {
        font-size: 5rem; opacity: 0.1;
        position: absolute; right: 1.5rem; top: 50%; transform: translateY(-50%);
    }

    /* ── Contador de resumen ── */
    .em-stats { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
    .em-stat {
        background: #fff; border: 1px solid #e2e8f0; border-radius: 0.5rem;
        padding: 0.6rem 1.1rem; display: flex; align-items: center; gap: 0.6rem;
        font-size: 0.875rem; font-weight: 600; min-width: 150px;
    }
    .em-stat .dot {
        width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
    }
    .dot-paro       { background: #ef4444; }
    .dot-produccion { background: #22c55e; }
    .dot-sinact     { background: #94a3b8; }

    /* ── Cards ── */
    .em-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
        gap: 1rem;
    }

    .em-card {
        background: #fff;
        border: 2px solid #e2e8f0;
        border-radius: 0.625rem;
        overflow: hidden;
        transition: box-shadow 0.2s, border-color 0.2s;
        display: flex;
        flex-direction: column;
    }
    .em-card:hover { box-shadow: 0 6px 18px rgba(0,0,0,0.09); }
    .em-card.estado-EnParo       { border-color: #ef4444; }
    .em-card.estado-EnProduccion { border-color: #22c55e; }
    .em-card.estado-SinActividad { border-color: #e2e8f0; }

    /* tira de color en el top */
    .em-card-bar {
        height: 4px;
        background: #e2e8f0;
    }
    .estado-EnParo       .em-card-bar { background: #ef4444; }
    .estado-EnProduccion .em-card-bar { background: #22c55e; }

    .em-card-header {
        padding: 0.875rem 1rem 0.625rem;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.5rem;
    }
    .em-machine-name {
        font-weight: 700; font-size: 0.9375rem; color: #1e293b; line-height: 1.3;
        word-break: break-word;
    }
    .em-machine-code {
        font-size: 0.75rem; color: #94a3b8; font-family: monospace;
    }
    .em-status-badge {
        font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.05em; padding: 0.25rem 0.6rem;
        border-radius: 99px; white-space: nowrap; flex-shrink: 0;
    }
    .badge-EnParo       { background: #fee2e2; color: #b91c1c; }
    .badge-EnProduccion { background: #dcfce7; color: #15803d; }
    .badge-SinActividad { background: #f1f5f9; color: #64748b; }

    .em-breadcrumb {
        font-size: 0.72rem; color: #94a3b8;
        padding: 0 1rem 0.625rem;
        display: flex; align-items: center; gap: 0.25rem; flex-wrap: wrap;
    }
    .em-breadcrumb i { font-size: 0.65rem; }

    .em-divider { border: none; border-top: 1px solid #f1f5f9; margin: 0; }

    .em-body { padding: 0.75rem 1rem; flex: 1; display: flex; flex-direction: column; gap: 0.6rem; }

    /* Sección paro */
    .em-section-title {
        font-size: 0.675rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.07em; color: #94a3b8; margin-bottom: 0.25rem;
    }
    .em-paro-row {
        display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem;
    }
    .em-dept-dot {
        width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0;
    }
    .em-paro-dept { font-weight: 600; color: #1e293b; }
    .em-paro-dur {
        margin-left: auto; font-size: 0.78rem;
        background: #fee2e2; color: #b91c1c; padding: 0.15rem 0.5rem;
        border-radius: 99px; font-weight: 700; white-space: nowrap;
    }

    /* Sección producción */
    .em-counters {
        display: flex; gap: 0.5rem;
    }
    .em-counter-box {
        flex: 1; border-radius: 0.4rem; padding: 0.4rem 0.6rem;
        display: flex; flex-direction: column; align-items: center;
    }
    .em-counter-box.ok  { background: #f0fdf4; }
    .em-counter-box.nok { background: #fff1f2; }
    .em-counter-val {
        font-size: 1.35rem; font-weight: 800; line-height: 1.1;
    }
    .em-counter-box.ok  .em-counter-val { color: #16a34a; }
    .em-counter-box.nok .em-counter-val { color: #e11d48; }
    .em-counter-lbl { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; opacity: 0.7; }
    .em-producto-tag {
        font-size: 0.78rem; color: #475569;
        display: flex; align-items: center; gap: 0.3rem;
        margin-top: 0.15rem;
    }

    /* Fallas */
    .em-fallas { display: flex; flex-wrap: wrap; gap: 0.3rem; }
    .em-falla-badge {
        font-size: 0.7rem; font-weight: 600;
        padding: 0.2rem 0.55rem; border-radius: 99px;
        border: 1px solid transparent;
        display: flex; align-items: center; gap: 0.25rem;
    }

    /* Sin actividad */
    .em-sinact {
        font-size: 0.82rem; color: #94a3b8;
        display: flex; align-items: center; gap: 0.4rem;
        padding: 0.25rem 0;
    }

    /* Footer */
    .em-card-footer {
        padding: 0.5rem 1rem;
        background: #f8fafc;
        border-top: 1px solid #f1f5f9;
        font-size: 0.72rem; color: #94a3b8;
        display: flex; align-items: center; justify-content: space-between;
    }

    /* Barra de refresco */
    .em-refresh-bar {
        height: 3px; background: #e2e8f0; border-radius: 99px; overflow: hidden;
        margin-top: 0.75rem;
    }
    .em-refresh-progress {
        height: 100%; background: #3b82f6; border-radius: 99px;
        transition: width 1s linear;
        width: 100%;
    }

    /* Skeleton */
    .em-skeleton {
        background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 0.375rem; height: 180px;
    }
    @@keyframes shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    .em-empty {
        text-align: center; padding: 3rem 1rem; color: #94a3b8;
        font-size: 0.9rem;
    }
    .em-empty i { font-size: 3rem; opacity: 0.3; display: block; margin-bottom: 0.75rem; }
</style>

<div class="container-fluid">

    <!-- Hero -->
    <div class="em-hero">
        <div style="position:relative;z-index:1;">
            <h1><i class="ph ph-factory me-2"></i>Estado de Máquinas</h1>
            <p>Vista en tiempo real del estado operativo de cada máquina — se refresca automáticamente</p>
        </div>
        <i class="ph ph-monitor-play hero-icon"></i>
    </div>

    <!-- Filtros -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-lg-2 col-md-4">
                    <label class="form-label mb-1 small fw-semibold">Área</label>
                    <select class="form-select form-select-sm" id="sel-area">
                        <option value="">Todas las áreas</option>
                        @foreach (var area in (List<WebApp.Models.Area>)ViewBag.Areas)
                        {
                            <option value="@area.Id">@area.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label mb-1 small fw-semibold">Línea</label>
                    <select class="form-select form-select-sm" id="sel-linea" disabled>
                        <option value="">Seleccione un área primero</option>
                        @foreach (var linea in (List<WebApp.Models.Linea>)ViewBag.Lineas)
                        {
                            <option value="@linea.Id" data-area="@linea.AreaId">@linea.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label mb-1 small fw-semibold">Rango de tiempo</label>
                    <select class="form-select form-select-sm" id="sel-rango-tiempo">
                        <option value="turno-actual">Turno actual</option>
                        <option value="24h">24 horas</option>
                        <option value="semana" selected>Semana</option>
                        <option value="mes">Mes</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-primary" id="btn-actualizar">
                        <i class="ph ph-arrows-clockwise me-1"></i>Actualizar ahora
                    </button>
                </div>
                <div class="col-auto">
                    <a href="@Url.Action("EstadoLineas", "Linealytics")" class="btn btn-sm btn-outline-secondary">
                        <i class="ph ph-lines me-1"></i>Ver por Líneas
                    </a>
                </div>
                <div class="col-auto ms-auto">
                    <span class="text-muted small" id="lbl-ultima-act">—</span>
                </div>
            </div>

            <!-- Barra de progreso refresco -->
            <div class="em-refresh-bar mt-2">
                <div class="em-refresh-progress" id="refresh-progress"></div>
            </div>
        </div>
    </div>

    <!-- Resumen -->
    <div class="em-stats" id="em-stats" style="display:none!important;"></div>

    <!-- Grid de máquinas -->
    <div id="em-grid-container">
        <!-- Skeletons iniciales -->
        <div class="em-grid" id="em-skeleton-grid">
            @for (int i = 0; i < 6; i++)
            {
                <div class="em-skeleton"></div>
            }
        </div>
        <div class="em-grid" id="em-grid" style="display:none;"></div>
        <div class="em-empty d-none" id="em-empty">
            <i class="ph ph-desktop-tower"></i>
            No se encontraron máquinas activas con los filtros seleccionados.
        </div>
    </div>

</div>

@section Scripts {
<script>
(function () {
    const INTERVAL_S = 30;
    let intervalHandle = null;
    let progressHandle = null;
    let secondsLeft = INTERVAL_S;

    const gridEl       = document.getElementById('em-grid');
    const skeletonEl   = document.getElementById('em-skeleton-grid');
    const emptyEl      = document.getElementById('em-empty');
    const statsEl      = document.getElementById('em-stats');
    const lblAct       = document.getElementById('lbl-ultima-act');
    const progressEl   = document.getElementById('refresh-progress');
    const selArea      = document.getElementById('sel-area');
    const selLinea     = document.getElementById('sel-linea');
    const selRangoTiempo = document.getElementById('sel-rango-tiempo');

    // ── Filtro Area/Linea ──────────────────────────────────────
    selArea.addEventListener('change', function () {
        const areaId = this.value;
        const opts = selLinea.querySelectorAll('option[data-area]');
        let visible = 0;
        opts.forEach(opt => {
            const show = !areaId || opt.dataset.area === areaId;
            opt.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        selLinea.value = '';
        selLinea.disabled = !areaId;
        if (!areaId) {
            selLinea.options[0].text = 'Todas las líneas';
        } else {
            selLinea.options[0].text = 'Todas las líneas del área';
        }
        cargar();
    });

    selLinea.addEventListener('change', cargar);
    selRangoTiempo.addEventListener('change', cargar);

    document.getElementById('btn-actualizar').addEventListener('click', function () {
        resetCountdown();
        cargar();
    });

    // ── Carga de datos ─────────────────────────────────────────
    async function cargar() {
        const areaId  = selArea.value  || '';
        const lineaId = selLinea.value || '';
        const rangoTiempo = selRangoTiempo.value || 'semana';
        const params  = new URLSearchParams();
        if (areaId)  params.append('areaId',  areaId);
        if (lineaId) params.append('lineaId', lineaId);
        params.append('rangoTiempo', rangoTiempo);

        try {
            const resp = await fetch('/Linealytics/GetEstadoMaquinas?' + params.toString());
            if (!resp.ok) throw new Error('HTTP ' + resp.status);
            const data = await resp.json();
            renderizar(data);
            lblAct.textContent = 'Última actualización: ' + new Date().toLocaleTimeString('es-MX');
        } catch (e) {
            console.error('Error cargando estado:', e);
            lblAct.textContent = 'Error al actualizar';
        }
    }

    // ── Render ─────────────────────────────────────────────────
    function renderizar(maquinas) {
        skeletonEl.style.display = 'none';

        if (!maquinas || maquinas.length === 0) {
            gridEl.style.display = 'none';
            emptyEl.classList.remove('d-none');
            statsEl.style.setProperty('display', 'none', 'important');
            return;
        }

        emptyEl.classList.add('d-none');
        gridEl.style.display = 'grid';

        // Resumen
        const nParo  = maquinas.filter(m => m.estado === 'EnParo').length;
        const nProd  = maquinas.filter(m => m.estado === 'EnProduccion').length;
        const nSin   = maquinas.filter(m => m.estado === 'SinActividad').length;

        statsEl.innerHTML = `
            <div class="em-stat"><span class="dot dot-paro"></span>${nParo} En Paro</div>
            <div class="em-stat"><span class="dot dot-produccion"></span>${nProd} En Producción</div>
            <div class="em-stat"><span class="dot dot-sinact"></span>${nSin} Sin Actividad</div>
            <div class="em-stat" style="border-color:#dbeafe;color:#1d4ed8;">
                <i class="ph ph-desktop-tower"></i> ${maquinas.length} Total
            </div>`;
        statsEl.style.removeProperty('display');

        gridEl.innerHTML = maquinas.map(m => cardHtml(m)).join('');
    }

    function cardHtml(m) {
        const badgeClass = 'badge-' + m.estado;
        const cardClass  = 'estado-' + m.estado;
        const badgeText  = m.estado === 'EnParo' ? '⛔ En Paro'
                         : m.estado === 'EnProduccion' ? '▶ En Producción'
                         : '○ Sin Actividad';

        // Breadcrumb
        const partes = [m.area, m.linea, m.estacion].filter(Boolean);
        const breadcrumb = partes.map((p, i) =>
            i < partes.length - 1
                ? `<span>${escHtml(p)}</span><i class="ph ph-caret-right"></i>`
                : `<span>${escHtml(p)}</span>`
        ).join('');

        // Cuerpo
        let cuerpo = '';

        // Paro
        if (m.paro) {
            cuerpo += `
            <div>
                <div class="em-section-title">Paro activo</div>
                <div class="em-paro-row">
                    <span class="em-dept-dot" style="background:${escHtml(m.paro.departamentoColor)}"></span>
                    <span class="em-paro-dept">${escHtml(m.paro.departamento ?? '—')}</span>
                    ${m.paro.boton ? `<span class="text-muted" style="font-size:.75rem;">(${escHtml(m.paro.boton)})</span>` : ''}
                    <span class="em-paro-dur"><i class="ph ph-timer"></i> ${m.paro.duracionMinutos} min</span>
                </div>
            </div>`;
        }

        // Corrida / Contadores
        if (m.corrida) {
            const totalPiezas = m.corrida.produccionOK + m.corrida.produccionNOK;
            const calidad = totalPiezas > 0
                ? ((m.corrida.produccionOK / totalPiezas) * 100).toFixed(1)
                : '—';
            cuerpo += `
            <div>
                <div class="em-section-title">Producción activa</div>
                ${m.corrida.productoNombre
                    ? `<div class="em-producto-tag">
                            <i class="ph ph-package"></i>
                            <span><strong>${escHtml(m.corrida.productoCodigo ?? '')}</strong> — ${escHtml(m.corrida.productoNombre)}</span>
                       </div>`
                    : ''}
                <div class="em-counters mt-1">
                    <div class="em-counter-box ok">
                        <span class="em-counter-val">${m.corrida.produccionOK.toLocaleString('es-MX')}</span>
                        <span class="em-counter-lbl">OK</span>
                    </div>
                    <div class="em-counter-box nok">
                        <span class="em-counter-val">${m.corrida.produccionNOK.toLocaleString('es-MX')}</span>
                        <span class="em-counter-lbl">NOK</span>
                    </div>
                    <div class="em-counter-box" style="background:#eff6ff;flex:.8;">
                        <span class="em-counter-val" style="color:#2563eb;font-size:1.1rem;">${calidad}%</span>
                        <span class="em-counter-lbl" style="color:#2563eb;">Calidad</span>
                    </div>
                </div>
            </div>`;
        }

        // Sin actividad
        if (m.estado === 'SinActividad') {
            cuerpo += `<div class="em-sinact"><i class="ph ph-moon"></i> Sin actividad registrada</div>`;
        }

        // Fallas
        if (m.fallas && m.fallas.length > 0) {
            const badgesFallas = m.fallas.map(f => {
                const sev = f.severidad ?? '';
                const bg  = severidadBg(sev);
                const fg  = severidadFg(sev);
                return `<span class="em-falla-badge" style="background:${bg};color:${fg};border-color:${fg}40;">
                    <i class="ph ph-warning"></i>${escHtml(f.tipo ?? sev)}
                </span>`;
            }).join('');
            cuerpo += `
            <div>
                <div class="em-section-title">Fallas activas (${m.fallas.length})</div>
                <div class="em-fallas">${badgesFallas}</div>
            </div>`;
        }

        // Tiempo en estado actual
        let tiempoEstado = '';
        if (m.paro) {
            tiempoEstado = `Paro desde hace ${m.paro.duracionMinutos} min`;
        } else if (m.corrida) {
            const mins = Math.round((Date.now() - new Date(m.corrida.inicio).getTime()) / 60000);
            tiempoEstado = `Corrida iniciada hace ${mins} min · ${m.corrida.lecturas} lecturas`;
        }

        return `
        <div class="em-card ${cardClass}">
            <div class="em-card-bar"></div>
            <div class="em-card-header">
                <div>
                    <div class="em-machine-name">${escHtml(m.nombre)}</div>
                    <div class="em-machine-code">${escHtml(m.codigo ?? '')}</div>
                </div>
                <span class="em-status-badge ${badgeClass}">${badgeText}</span>
            </div>
            <div class="em-breadcrumb">${breadcrumb}</div>
            <hr class="em-divider">
            <div class="em-body">${cuerpo}</div>
            <div class="em-card-footer">
                <span><i class="ph ph-clock me-1"></i>${tiempoEstado || 'Sin actividad reciente'}</span>
                <a href="/Linealytics/CorridasProduccion?maquinaId=${m.maquinaId}" class="text-primary" style="font-size:.72rem;">Ver corridas</a>
            </div>
        </div>`;
    }

    // ── Helpers ────────────────────────────────────────────────
    function severidadBg(s) {
        return s === 'Crítica' ? '#fff1f2' : s === 'Alta' ? '#fff7ed'
             : s === 'Media'   ? '#fffbeb' : '#f0fdf4';
    }
    function severidadFg(s) {
        return s === 'Crítica' ? '#be123c' : s === 'Alta' ? '#c2410c'
             : s === 'Media'   ? '#b45309' : '#15803d';
    }
    function escHtml(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    // ── Auto-refresco con barra de progreso ────────────────────
    function resetCountdown() {
        secondsLeft = INTERVAL_S;
        if (progressHandle) clearInterval(progressHandle);
        progressEl.style.transition = 'none';
        progressEl.style.width = '100%';
        void progressEl.offsetWidth; // reflow
        progressEl.style.transition = 'width 1s linear';

        progressHandle = setInterval(() => {
            secondsLeft--;
            const pct = (secondsLeft / INTERVAL_S) * 100;
            progressEl.style.width = pct + '%';
            if (secondsLeft <= 0) {
                clearInterval(progressHandle);
            }
        }, 1000);
    }

    function iniciarAutoRefresh() {
        if (intervalHandle) clearInterval(intervalHandle);
        intervalHandle = setInterval(() => {
            resetCountdown();
            cargar();
        }, INTERVAL_S * 1000);
    }

    // ── Inicializar ────────────────────────────────────────────
    resetCountdown();
    iniciarAutoRefresh();
    cargar();

})();
</script>
}
