@{
    ViewData["Title"] = "Paros de Línea";
}

<style>
    /* Hero */
    .lnx-hero {
        background: linear-gradient(135deg, #7c2d12 0%, #c2410c 100%);
        border-radius: 0.375rem;
        padding: 2.5rem 2rem;
        color: #fff;
        position: relative;
        overflow: hidden;
        margin-bottom: 1.75rem;
    }

    .lnx-hero::after {
        content: '';
        position: absolute;
        right: -40px;
        top: -40px;
        width: 220px;
        height: 220px;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 50%;
    }

    .lnx-hero::before {
        content: '';
        position: absolute;
        right: 60px;
        bottom: -60px;
        width: 160px;
        height: 160px;
        background: rgba(255, 255, 255, 0.06);
        border-radius: 50%;
    }

    .lnx-hero h1 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.4rem;
    }

    .lnx-hero p {
        opacity: 0.8;
        margin-bottom: 0;
        font-size: 0.9375rem;
    }

    .lnx-hero .hero-icon {
        font-size: 5rem;
        opacity: 0.12;
        position: absolute;
        right: 2rem;
        top: 50%;
        transform: translateY(-50%);
        line-height: 1;
    }

    /* Section label */
    .lnx-section-label {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 1rem;
        color: #64748b;
    }

    .lnx-section-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e2e8f0;
    }

    .lnx-section-label .badge-label {
        background: #f1f5f9;
        border-radius: 99px;
        padding: 0.25rem 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    /* Module cards */
    .lnx-card {
        border: 1px solid #e9ecef;
        border-radius: 0.5rem;
        background: #fff;
        height: 100%;
        transition: box-shadow 0.2s ease, transform 0.2s ease, border-color 0.2s ease;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .lnx-card:hover {
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        transform: translateY(-3px);
        border-color: transparent;
    }

    .lnx-card-top {
        padding: 1.25rem 1.25rem 0;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .lnx-icon-box {
        width: 2.75rem;
        height: 2.75rem;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.3rem;
    }

    .lnx-card-title {
        font-weight: 600;
        font-size: 0.9375rem;
        color: #1e293b;
        margin-bottom: 0.2rem;
        line-height: 1.3;
    }

    .lnx-card-desc {
        font-size: 0.8125rem;
        color: #94a3b8;
        line-height: 1.5;
    }

    .lnx-card-footer {
        padding: 1rem 1.25rem 1.25rem;
        margin-top: auto;
    }

    .lnx-card-footer a {
        font-size: 0.8125rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        text-decoration: none;
        transition: gap 0.2s;
    }

    .lnx-card-footer a:hover {
        gap: 0.6rem;
    }

    /* Color variants */
    .lnx-icon-blue   { background: #eff6ff; color: #2563eb; }
    .lnx-icon-red    { background: #fff1f2; color: #e11d48; }
    .lnx-icon-teal   { background: #f0fdfa; color: #0d9488; }
    .lnx-icon-slate  { background: #f8fafc; color: #475569; }
    .lnx-icon-amber  { background: #fffbeb; color: #d97706; }
    .lnx-icon-green  { background: #f0fdf4; color: #16a34a; }
    .lnx-icon-purple { background: #faf5ff; color: #7c3aed; }
    .lnx-icon-orange { background: #fff7ed; color: #ea580c; }

    .lnx-link-blue   { color: #2563eb; }
    .lnx-link-red    { color: #e11d48; }
    .lnx-link-teal   { color: #0d9488; }
    .lnx-link-slate  { color: #475569; }
    .lnx-link-amber  { color: #d97706; }
    .lnx-link-green  { color: #16a34a; }
    .lnx-link-purple { color: #7c3aed; }
    .lnx-link-orange { color: #ea580c; }
</style>

<div class="container-fluid">
    <!-- Hero -->
    <div class="lnx-hero">
        <h1>Paros de Línea</h1>
        <p>Gestiona y monitorea los paros de línea en tiempo real</p>
        <i class="ph ph-stop-circle hero-icon"></i>
    </div>

    <!-- ── PAROS DE LÍNEA ── -->
    <div class="lnx-section-label">
        <div class="badge-label">
            <i class="ph ph-stop-circle"></i>Paros de Línea
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-md-6">
            <div class="lnx-card">
                <div class="lnx-card-top">
                    <div class="lnx-icon-box lnx-icon-blue">
                        <i class="ph ph-chart-bar"></i>
                    </div>
                    <div>
                        <div class="lnx-card-title">Timeline de Paros</div>
                        <div class="lnx-card-desc">Visualiza la disponibilidad en tiempo real</div>
                    </div>
                </div>
                <div class="lnx-card-footer">
                    <a asp-action="Dashboard" class="lnx-link-blue">
                        Ver Dashboard <i class="ph ph-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="lnx-card">
                <div class="lnx-card-top">
                    <div class="lnx-icon-box lnx-icon-red">
                        <i class="ph ph-prohibit"></i>
                    </div>
                    <div>
                        <div class="lnx-card-title">Paros Registrados</div>
                        <div class="lnx-card-desc">Historial completo de paros por botonera</div>
                    </div>
                </div>
                <div class="lnx-card-footer">
                    <a asp-action="ParosLinea" class="lnx-link-red">
                        Ver Paros <i class="ph ph-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="lnx-card">
                <div class="lnx-card-top">
                    <div class="lnx-icon-box lnx-icon-teal">
                        <i class="ph ph-hand-tap"></i>
                    </div>
                    <div>
                        <div class="lnx-card-title">Botones</div>
                        <div class="lnx-card-desc">Botones asignados por departamento</div>
                    </div>
                </div>
                <div class="lnx-card-footer">
                    <a asp-action="Botones" class="lnx-link-teal">
                        Administrar <i class="ph ph-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="lnx-card">
                <div class="lnx-card-top">
                    <div class="lnx-icon-box lnx-icon-slate">
                        <i class="ph ph-device-mobile-speaker"></i>
                    </div>
                    <div>
                        <div class="lnx-card-title">Botoneras</div>
                        <div class="lnx-card-desc">Dispositivos físicos por máquina</div>
                    </div>
                </div>
                <div class="lnx-card-footer">
                    <a asp-action="Botoneras" class="lnx-link-slate">
                        Administrar <i class="ph ph-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="lnx-card">
                <div class="lnx-card-top">
                    <div class="lnx-icon-box lnx-icon-amber">
                        <i class="ph ph-chat-text"></i>
                    </div>
                    <div>
                        <div class="lnx-card-title">Comentarios de Paros</div>
                        <div class="lnx-card-desc">Documenta y gestiona paros cerrados</div>
                    </div>
                </div>
                <div class="lnx-card-footer">
                    <a asp-action="ParosSinComentar" class="lnx-link-amber">
                        Gestionar <i class="ph ph-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
