@model WebApp.Models.Linealytics.Turno

@{
    ViewData["Title"] = "Editar Turno";
}

<div class="container-fluid">
    <div class="card mt-3">
        <div class="card-header">
            <h4 class="mb-0">
                <i class="ph ph-pencil-simple me-2"></i>Editar Turno
            </h4>
        </div>
        <div class="card-body">
            <form asp-action="EditTurno" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Nombre" class="form-label">Nombre del Turno</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="HoraInicio" class="form-label">Hora de Inicio</label>
                        <input asp-for="HoraInicio" class="form-control" type="time" id="HoraInicio" />
                        <span asp-validation-for="HoraInicio" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="HoraFin" class="form-label">Hora de Fin</label>
                        <input asp-for="HoraFin" class="form-control" type="time" id="HoraFin" />
                        <span asp-validation-for="HoraFin" class="text-danger"></span>
                        <small class="text-muted" id="lbl-duracion"></small>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="form-check">
                            <input asp-for="Activo" class="form-check-input" type="checkbox" />
                            <label asp-for="Activo" class="form-check-label">
                                Activo
                            </label>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="ph ph-floppy-disk me-1"></i>Guardar Cambios
                    </button>
                    <a asp-action="Turnos" class="btn btn-secondary">
                        <i class="ph ph-x-circle me-1"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
    (function () {
        const inicio = document.getElementById('HoraInicio');
        const fin    = document.getElementById('HoraFin');
        const lbl    = document.getElementById('lbl-duracion');
        function actualizar() {
            if (!inicio.value || !fin.value) { lbl.textContent = ''; return; }
            const [hI, mI] = inicio.value.split(':').map(Number);
            const [hF, mF] = fin.value.split(':').map(Number);
            let mins = (hF * 60 + mF) - (hI * 60 + mI);
            if (mins <= 0) mins += 1440;
            const h = Math.floor(mins / 60), m = mins % 60;
            lbl.textContent = `Duración calculada: ${h}h ${m}min (${mins} min)`;
        }
        inicio.addEventListener('change', actualizar);
        fin.addEventListener('change', actualizar);
        actualizar(); // mostrar duración actual al cargar
    })();
    </script>
}
