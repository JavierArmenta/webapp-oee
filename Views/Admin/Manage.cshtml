@using WebApp.Enums
@model List<ManageUserRolesViewModel>
@{
    ViewData["Title"] = "Administrar Roles";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="page-header">
        <h1 class="page-header-title">
            <i class="ph ph-shield"></i>Roles de @ViewBag.UserName
        </h1>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="ph ph-arrow-left me-1"></i>Volver
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="ph ph-user-gear me-2"></i>Asignar Roles</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <div class="form-check mb-2">
                                <input type="hidden" asp-for="@Model[i].RoleId" />
                                <input type="hidden" asp-for="@Model[i].RoleName" />
                                <input asp-for="@Model[i].Selected" class="form-check-input" />
                                <label class="form-check-label fw-medium" asp-for="@Model[i].Selected">
                                    @Model[i].RoleName
                                </label>
                            </div>
                        }
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="ph ph-floppy-disk me-1"></i>Actualizar Roles
                            </button>
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary">
                                <i class="ph ph-x me-1"></i>Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
}