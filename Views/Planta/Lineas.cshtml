@model IEnumerable<WebApp.Models.Linea>

@{
    ViewData["Title"] = "Gestión de Líneas";
}

<div class="container-fluid">

    <div class="page-header">
        <h1 class="page-header-title">
            <i class="ph ph-tree-structure"></i>Líneas de Producción
        </h1>
        <a asp-action="CreateLinea" class="btn btn-primary btn-sm">
            <i class="ph ph-plus-circle me-1"></i>Nueva Línea
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="ph ph-tray display-1 text-muted"></i>
                    <p class="text-muted mt-3">No hay líneas registradas.</p>
                    <a asp-action="CreateLinea" class="btn btn-primary">
                        <i class="ph ph-plus-circle me-1"></i>Crear primera línea
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle datatable-basic">
                        <thead class="table-light">
                        <tr>
                            <th style="width:1%;white-space:nowrap">Código</th>
                            <th>Nombre</th>
                            <th>Área</th>
                            <th class="text-center" style="width:1%;white-space:nowrap">Estaciones</th>
                            <th class="text-center" style="width:1%;white-space:nowrap">Estado</th>
                            <th class="text-end" style="width:1%;white-space:nowrap">Acciones</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(!item.Activo ? "table-secondary" : "")">
                                <td>
                                    <code>@item.Codigo</code>
                                </td>
                                <td>
                                    <strong>@item.Nombre</strong>
                                </td>
                                <td>
                                    <a asp-action="AreaDetails" asp-route-id="@item.AreaId">
                                        @item.Area.Nombre
                                    </a>
                                </td>
                                <td class="text-center text-nowrap">
                                    <span class="badge bg-info">@item.Estaciones.Count</span>
                                </td>
                                <td class="text-center text-nowrap">
                                    @if (item.Activo)
                                    {
                                        <span class="badge bg-success">
                                            <i class="ph ph-check me-1"></i>Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="ph ph-x me-1"></i>Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="text-nowrap text-end">
                                    <a asp-action="LineaDetails" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                        <i class="ph ph-eye"></i> Ver
                                    </a>
                                    <a asp-action="EditLinea" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        <i class="ph ph-pencil-simple"></i> Editar
                                    </a>
                                    @if (item.Activo)
                                    {
                                        <form asp-action="DeactivateLinea" asp-route-id="@item.Id" method="post" class="d-inline deactivate-form">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-sm btn-warning deactivate-linea-btn">
                                                <i class="ph ph-toggle-left me-1"></i>Desactivar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="ActivateLinea" asp-route-id="@item.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success">
                                                <i class="ph ph-toggle-right me-1"></i>Activar
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/js/jquery/jquery.min.js"></script>
    <script src="~/assets/js/vendor/tables/datatables/datatables.min.js"></script>

    <script src="~/assets/js/vendor/notifications/sweet_alert.min.js"></script>
    <script src="~/assets/demo/pages/extra_sweetalert.js"></script>

    <script>
        // Inicializar SweetAlert
        const swalInit = swal.mixin({
            buttonsStyling: false,
            customClass: {
                confirmButton: 'btn btn-success',
                cancelButton: 'btn btn-danger'
            }
        });

        // Inicializar DataTables
        const _componentDatatableBasic = function() {
            if (!$().DataTable) {
                console.warn('Warning - datatables.min.js is not loaded.');
                return;
            }

            // Setting datatable defaults
            $.extend( $.fn.dataTable.defaults, {
                autoWidth: false,
                columnDefs: [
                    {
                        orderable: false,
                        targets: [ 5 ],
                        width: '280px'
                    }
                ],
                dom: '<"datatable-header"fl><"datatable-scroll"t><"datatable-footer"ip>',
                language: {
                    search: '<span class="me-3">Filter:</span> <div class="form-control-feedback form-control-feedback-end flex-fill">_INPUT_<div class="form-control-feedback-icon"><i class="ph-magnifying-glass opacity-50"></i></div></div>',
                    searchPlaceholder: 'Type to filter...',
                    lengthMenu: '<span class="me-3">Show:</span> _MENU_',
                    paginate: { 'first': 'First', 'last': 'Last', 'next': document.dir == "rtl" ? '&larr;' : '&rarr;', 'previous': document.dir == "rtl" ? '&rarr;' : '&larr;' }
                }
            });

            // Basic datatable
            $('.datatable-basic').DataTable();
        };

        // Inicializar al cargar el documento
        document.addEventListener('DOMContentLoaded', function() {
            _componentDatatableBasic();

            // Confirmación para desactivar línea
            const deactivateButtons = document.querySelectorAll('.deactivate-linea-btn');

            deactivateButtons.forEach(function(button) {
                button.addEventListener('click', function() {
                    const form = this.closest('.deactivate-form');

                    swalInit.fire({
                        title: '¿Está seguro?',
                        text: "¿Desea desactivar esta línea?",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Sí, desactivar',
                        cancelButtonText: 'No, cancelar',
                        buttonsStyling: false,
                        customClass: {
                            confirmButton: 'btn btn-success',
                            cancelButton: 'btn btn-danger'
                        }
                    }).then(function(result) {
                        if(result.value) {
                            form.submit();
                        }
                        else if(result.dismiss === swal.DismissReason.cancel) {
                            swalInit.fire(
                                'Cancelado',
                                'La línea no ha sido desactivada',
                                'info'
                            );
                        }
                    });
                });
            });

            // Mostrar notificaciones de éxito
            @if (TempData["Success"] != null)
            {
                <text>
                swalInit.fire({
                    title: '¡Éxito!',
                    text: '@TempData["Success"]',
                    icon: 'success',
                    confirmButtonText: 'OK',
                    buttonsStyling: false,
                    customClass: {
                        confirmButton: 'btn btn-success'
                    }
                });
                </text>
            }

            // Mostrar notificaciones de error
            @if (TempData["Error"] != null)
            {
                <text>
                swalInit.fire({
                    title: 'Error',
                    text: '@TempData["Error"]',
                    icon: 'error',
                    confirmButtonText: 'OK',
                    buttonsStyling: false,
                    customClass: {
                        confirmButton: 'btn btn-danger'
                    }
                });
                </text>
            }
        });
    </script>
}
